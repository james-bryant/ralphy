<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane id="shellRoot" prefHeight="800.0" prefWidth="1280.0" xmlns:fx="http://javafx.com/fxml"
            fx:controller="net.uberfoo.ai.ralphy.AppShellController">
    <left>
        <VBox id="navigationPane" fx:id="navigationPane" prefWidth="260.0" spacing="16.0">
            <styleClass>
                <String fx:value="shell-sidebar"/>
            </styleClass>
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0"/>
            </padding>
            <Label id="brandLabel" fx:id="brandLabel">
                <styleClass>
                    <String fx:value="shell-brand"/>
                </styleClass>
            </Label>
            <Label id="taglineLabel" fx:id="taglineLabel" wrapText="true">
                <styleClass>
                    <String fx:value="muted-text"/>
                </styleClass>
            </Label>
            <Separator/>
            <Label text="Navigation">
                <styleClass>
                    <String fx:value="section-title"/>
                </styleClass>
            </Label>
            <Button id="projectsNavButton" fx:id="projectsNavButton" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#showProjects" text="Projects">
                <styleClass>
                    <String fx:value="shell-nav-button"/>
                </styleClass>
            </Button>
            <Button id="prdEditorNavButton" fx:id="prdEditorNavButton" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#showPrdEditor" text="PRD Editor">
                <styleClass>
                    <String fx:value="shell-nav-button"/>
                </styleClass>
            </Button>
            <Button id="executionNavButton" fx:id="executionNavButton" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#showExecution" text="Execution">
                <styleClass>
                    <String fx:value="shell-nav-button"/>
                </styleClass>
            </Button>
            <Region VBox.vgrow="ALWAYS"/>
            <Label id="navigationPlaceholderLabel" fx:id="navigationPlaceholderLabel" wrapText="true">
                <styleClass>
                    <String fx:value="muted-text"/>
                </styleClass>
            </Label>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true">
            <styleClass>
                <String fx:value="workspace-scroll-pane"/>
            </styleClass>
            <content>
                <VBox id="workspacePane" fx:id="workspacePane" spacing="18.0">
                    <styleClass>
                        <String fx:value="shell-workspace"/>
                    </styleClass>
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
                    </padding>
                    <Label id="workspaceTitleLabel" fx:id="workspaceTitleLabel" text="Workspace">
                        <styleClass>
                            <String fx:value="workspace-title"/>
                        </styleClass>
                    </Label>
                    <Label id="workspacePlaceholderLabel" fx:id="workspacePlaceholderLabel" wrapText="true">
                        <styleClass>
                            <String fx:value="muted-text"/>
                        </styleClass>
                    </Label>
                    <HBox spacing="16.0">
                        <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                            <styleClass>
                                <String fx:value="shell-card"/>
                            </styleClass>
                            <padding>
                                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                            </padding>
                            <Label text="Project Context">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label text="Open an existing local Git repository or create a new one to make it the active project."
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Button id="openRepositoryButton" fx:id="openRepositoryButton" mnemonicParsing="false"
                                    onAction="#openExistingRepository" text="Open Existing Repository"/>
                            <Label text="Create New Repository">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <Label text="Enter a folder name, then choose the parent folder where the new repository should be created."
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <HBox spacing="12.0">
                                <TextField id="newProjectNameField" fx:id="newProjectNameField" HBox.hgrow="ALWAYS"
                                           promptText="my-ralphy-project"/>
                                <Button id="createRepositoryButton" fx:id="createRepositoryButton" mnemonicParsing="false"
                                        onAction="#createNewRepository" text="Create New Repository"/>
                            </HBox>
                            <Label text="Active Repository">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <Label id="activeProjectNameLabel" fx:id="activeProjectNameLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label id="activeProjectPathLabel" fx:id="activeProjectPathLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Label id="projectValidationMessageLabel" fx:id="projectValidationMessageLabel" visible="false"
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="validation-text"/>
                                </styleClass>
                            </Label>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                            <styleClass>
                                <String fx:value="shell-card"/>
                            </styleClass>
                            <padding>
                                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                            </padding>
                            <Label text="Execution Profile">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label text="Save the Codex execution mode for the active project before starting native Windows or WSL runs."
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Label id="executionProfileSummaryLabel" fx:id="executionProfileSummaryLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <HBox spacing="12.0">
                                <RadioButton id="nativeExecutionProfileRadioButton" fx:id="nativeExecutionProfileRadioButton"
                                             mnemonicParsing="false" text="Native PowerShell"/>
                                <RadioButton id="wslExecutionProfileRadioButton" fx:id="wslExecutionProfileRadioButton"
                                             mnemonicParsing="false" text="WSL"/>
                            </HBox>
                            <TextField id="wslDistributionField" fx:id="wslDistributionField"
                                       promptText="Ubuntu-24.04"/>
                            <TextField id="windowsPathPrefixField" fx:id="windowsPathPrefixField"
                                       promptText="C:\Users\james\workspaces"/>
                            <TextField id="wslPathPrefixField" fx:id="wslPathPrefixField"
                                       promptText="/mnt/c/Users/james/workspaces"/>
                            <Button id="saveExecutionProfileButton" fx:id="saveExecutionProfileButton"
                                    mnemonicParsing="false" onAction="#saveExecutionProfile" text="Save Execution Profile"/>
                            <Label id="executionProfileMessageLabel" fx:id="executionProfileMessageLabel" visible="false"
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="validation-text"/>
                                </styleClass>
                            </Label>
                            <Separator/>
                            <Label text="Execution Overview">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label id="executionOverviewHeadlineLabel" fx:id="executionOverviewHeadlineLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <Label id="executionOverviewDetailLabel" fx:id="executionOverviewDetailLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Separator/>
                            <Label text="Native Windows Preflight">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label id="nativePreflightSummaryLabel" fx:id="nativePreflightSummaryLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <Label id="nativePreflightDetailLabel" fx:id="nativePreflightDetailLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Button id="runNativePreflightButton" fx:id="runNativePreflightButton"
                                    mnemonicParsing="false" onAction="#runNativeWindowsPreflight"
                                    text="Run Native Preflight"/>
                            <Label id="nativePreflightChecksLabel" fx:id="nativePreflightChecksLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <VBox id="nativePreflightRemediationSection" fx:id="nativePreflightRemediationSection"
                                  spacing="12.0" visible="false">
                                <Separator/>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Native Remediation">
                                        <styleClass>
                                            <String fx:value="section-title"/>
                                        </styleClass>
                                    </Label>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button id="rerunNativePreflightFromRemediationButton"
                                            fx:id="rerunNativePreflightFromRemediationButton"
                                            mnemonicParsing="false" onAction="#runNativeWindowsPreflight"
                                            text="Rerun Native Preflight"/>
                                </HBox>
                                <Label text="Copy the commands you want to run. Ralphy never installs or authenticates Codex automatically."
                                       wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <VBox id="nativePreflightRemediationContainer" fx:id="nativePreflightRemediationContainer"
                                      spacing="12.0"/>
                            </VBox>
                            <Label id="nativePreflightMessageLabel" fx:id="nativePreflightMessageLabel" visible="false"
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="validation-text"/>
                                </styleClass>
                            </Label>
                            <Separator/>
                            <Label text="WSL Preflight">
                                <styleClass>
                                    <String fx:value="card-title"/>
                                </styleClass>
                            </Label>
                            <Label id="wslPreflightSummaryLabel" fx:id="wslPreflightSummaryLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="section-title"/>
                                </styleClass>
                            </Label>
                            <Label id="wslPreflightDetailLabel" fx:id="wslPreflightDetailLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <Button id="runWslPreflightButton" fx:id="runWslPreflightButton"
                                    mnemonicParsing="false" onAction="#runWslPreflight"
                                    text="Run WSL Preflight"/>
                            <Label id="wslPreflightChecksLabel" fx:id="wslPreflightChecksLabel" wrapText="true">
                                <styleClass>
                                    <String fx:value="muted-text"/>
                                </styleClass>
                            </Label>
                            <VBox id="wslPreflightRemediationSection" fx:id="wslPreflightRemediationSection"
                                  spacing="12.0" visible="false">
                                <Separator/>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="WSL Remediation">
                                        <styleClass>
                                            <String fx:value="section-title"/>
                                        </styleClass>
                                    </Label>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button id="rerunWslPreflightFromRemediationButton"
                                            fx:id="rerunWslPreflightFromRemediationButton"
                                            mnemonicParsing="false" onAction="#runWslPreflight"
                                            text="Rerun WSL Preflight"/>
                                </HBox>
                                <Label text="Copy the commands you want to run. Ralphy never installs or authenticates Codex automatically."
                                       wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <VBox id="wslPreflightRemediationContainer" fx:id="wslPreflightRemediationContainer"
                                      spacing="12.0"/>
                            </VBox>
                            <Label id="wslPreflightMessageLabel" fx:id="wslPreflightMessageLabel" visible="false"
                                   wrapText="true">
                                <styleClass>
                                    <String fx:value="validation-text"/>
                                </styleClass>
                            </Label>
                        </VBox>
                    </HBox>
                    <VBox id="presetCatalogCard" fx:id="presetCatalogCard" spacing="16.0">
                        <styleClass>
                            <String fx:value="shell-card"/>
                        </styleClass>
                        <padding>
                            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                        </padding>
                        <Label text="Built-In Preset Catalog">
                            <styleClass>
                                <String fx:value="card-title"/>
                            </styleClass>
                        </Label>
                        <Label text="Select a built-in Ralph/Codex preset and inspect its versioned prompt preview. v1 intentionally keeps the prompt text read-only."
                               wrapText="true">
                            <styleClass>
                                <String fx:value="muted-text"/>
                            </styleClass>
                        </Label>
                        <HBox spacing="18.0">
                            <VBox prefWidth="250.0" spacing="10.0">
                                <Label text="Workflow Step">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <RadioButton id="prdCreationPresetRadioButton" fx:id="prdCreationPresetRadioButton"
                                             mnemonicParsing="false" text="PRD Creation"/>
                                <RadioButton id="storyImplementationPresetRadioButton"
                                             fx:id="storyImplementationPresetRadioButton"
                                             mnemonicParsing="false" text="Story Implementation"/>
                                <RadioButton id="retryFixPresetRadioButton" fx:id="retryFixPresetRadioButton"
                                             mnemonicParsing="false" text="Retry/Fix"/>
                                <RadioButton id="runSummaryPresetRadioButton" fx:id="runSummaryPresetRadioButton"
                                             mnemonicParsing="false" text="Run Summary"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                                <Label id="presetPreviewNameLabel" fx:id="presetPreviewNameLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="card-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="presetPreviewVersionLabel" fx:id="presetPreviewVersionLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="presetPreviewOverviewLabel" fx:id="presetPreviewOverviewLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <Label text="Required Skills">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="presetRequiredSkillsValueLabel" fx:id="presetRequiredSkillsValueLabel"
                                       wrapText="true"/>
                                <Label text="Operating Assumptions">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="presetAssumptionsValueLabel" fx:id="presetAssumptionsValueLabel"
                                       wrapText="true"/>
                                <Label text="Prompt Preview">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label text="Preset preview is read-only in v1. Arbitrary prompt editing stays disabled."
                                       wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <TextArea id="presetPromptPreviewArea" fx:id="presetPromptPreviewArea"
                                          editable="false" prefRowCount="10" wrapText="true">
                                    <styleClass>
                                        <String fx:value="preset-preview-area"/>
                                    </styleClass>
                                </TextArea>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox id="prdInterviewCard" fx:id="prdInterviewCard" spacing="16.0">
                        <styleClass>
                            <String fx:value="shell-card"/>
                        </styleClass>
                        <padding>
                            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                        </padding>
                        <Label text="PRD Interview Engine">
                            <styleClass>
                                <String fx:value="card-title"/>
                            </styleClass>
                        </Label>
                        <Label id="prdInterviewSummaryLabel" fx:id="prdInterviewSummaryLabel" wrapText="true">
                            <styleClass>
                                <String fx:value="section-title"/>
                            </styleClass>
                        </Label>
                        <HBox spacing="18.0">
                            <VBox prefWidth="280.0" spacing="10.0">
                                <Label text="Question Sequence">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label text="Move through the clarification prompts in order or revisit any saved answer before PRD generation."
                                       wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <VBox id="prdInterviewQuestionsContainer" fx:id="prdInterviewQuestionsContainer"
                                      spacing="8.0"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                                <Label id="prdInterviewQuestionCounterLabel" fx:id="prdInterviewQuestionCounterLabel"
                                       wrapText="true">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="prdInterviewSectionLabel" fx:id="prdInterviewSectionLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="section-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="prdInterviewTitleLabel" fx:id="prdInterviewTitleLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="card-title"/>
                                    </styleClass>
                                </Label>
                                <Label id="prdInterviewPromptLabel" fx:id="prdInterviewPromptLabel" wrapText="true"/>
                                <Label id="prdInterviewGuidanceLabel" fx:id="prdInterviewGuidanceLabel" wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                                <TextArea id="prdInterviewAnswerArea" fx:id="prdInterviewAnswerArea"
                                          prefRowCount="10"
                                          promptText="Capture the current draft answer here."
                                          wrapText="true">
                                    <styleClass>
                                        <String fx:value="interview-answer-area"/>
                                    </styleClass>
                                </TextArea>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Button id="prdInterviewPreviousButton" fx:id="prdInterviewPreviousButton"
                                            mnemonicParsing="false" onAction="#showPreviousPrdInterviewQuestion"
                                            text="Previous"/>
                                    <Button id="prdInterviewNextButton" fx:id="prdInterviewNextButton"
                                            mnemonicParsing="false" onAction="#showNextPrdInterviewQuestion"
                                            text="Next"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button id="prdInterviewSaveButton" fx:id="prdInterviewSaveButton"
                                            mnemonicParsing="false" onAction="#savePrdInterviewDraft"
                                            text="Save Draft"/>
                                </HBox>
                                <Label id="prdInterviewDraftStateLabel" fx:id="prdInterviewDraftStateLabel"
                                       visible="false" wrapText="true">
                                    <styleClass>
                                        <String fx:value="muted-text"/>
                                    </styleClass>
                                </Label>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
    <bottom>
        <HBox id="statusPane" fx:id="statusPane" alignment="CENTER_LEFT" spacing="12.0">
            <styleClass>
                <String fx:value="shell-status-bar"/>
            </styleClass>
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="12.0"/>
            </padding>
            <Label text="Status">
                <styleClass>
                    <String fx:value="status-title"/>
                </styleClass>
            </Label>
            <Label id="statusLabel" fx:id="statusLabel"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Active Project">
                <styleClass>
                    <String fx:value="status-title"/>
                </styleClass>
            </Label>
            <Label id="activeProjectStatusLabel" fx:id="activeProjectStatusLabel"/>
            <Label text="Windows-first application shell">
                <styleClass>
                    <String fx:value="muted-text"/>
                </styleClass>
            </Label>
        </HBox>
    </bottom>
</BorderPane>
